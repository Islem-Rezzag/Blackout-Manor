{
  "name": "@blackout-manor/client-game",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "lint": "biome check .",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --project tsconfig.json --noEmit"
  },
  "dependencies": {
    "@blackout-manor/content": "workspace:*",
    "@blackout-manor/replay-viewer": "workspace:*",
    "@blackout-manor/shared": "workspace:*",
    "colyseus.js": "^0.16.22",
    "phaser": "^3.90.0"
  }
}

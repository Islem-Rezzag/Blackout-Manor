{
  "name": "blackout-manor",
  "version": "0.1.0",
  "private": true,
  "description": "Monorepo scaffold for the Blackout Manor AI social-thriller.",
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.32.1"
  },
  "scripts": {
    "build": "turbo run build",
    "build:runtime": "turbo run build --filter=@blackout-manor/shared --filter=@blackout-manor/content --filter=@blackout-manor/engine --filter=@blackout-manor/agents --filter=@blackout-manor/client-game --filter=@blackout-manor/replay-viewer --filter=@blackout-manor/db",
    "check": "pnpm lint && pnpm typecheck && pnpm test",
    "ci:fairness": "pnpm fairness:check",
    "ci:quality": "pnpm lint && pnpm typecheck && pnpm test && pnpm build",
    "db:check": "pnpm --filter @blackout-manor/db lint && pnpm --filter @blackout-manor/db typecheck && pnpm --filter @blackout-manor/db test",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f postgres redis",
    "db:up": "docker compose up -d postgres redis",
    "predev": "pnpm build:runtime",
    "dev": "turbo run dev --parallel --filter=@blackout-manor/web --filter=@blackout-manor/server",
    "predev:server": "pnpm build:runtime",
    "dev:server": "pnpm --filter @blackout-manor/server dev",
    "predev:web": "pnpm build:runtime",
    "dev:web": "pnpm --filter @blackout-manor/web dev",
    "prefairness:check": "pnpm build:runtime",
    "fairness:check": "tsx scripts/fairness-report.ts --count 100 --assert-thresholds",
    "prefairness:report": "pnpm build:runtime",
    "fairness:report": "tsx scripts/fairness-report.ts --count 100",
    "format": "biome format --write .",
    "lint": "biome check . && turbo run lint",
    "media:capture": "tsx scripts/capture-media.ts",
    "replay:open": "tsx scripts/replay-open.ts",
    "preserver:bot-match": "pnpm build:runtime",
    "server:bot-match": "pnpm --filter @blackout-manor/server bot:match",
    "preserver:start": "pnpm build:runtime",
    "server:start": "pnpm --filter @blackout-manor/server local",
    "test": "turbo run test",
    "test:e2e": "playwright test",
    "typecheck": "turbo run typecheck",
    "presim": "pnpm build:runtime",
    "sim": "tsx scripts/sim.ts",
    "presim:batch": "pnpm build:runtime",
    "sim:batch": "tsx scripts/sim-batch.ts",
    "preseed-suite": "pnpm build:runtime",
    "seed-suite": "tsx scripts/seed-suite.ts",
    "export:highlight": "tsx scripts/export-highlight.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.7",
    "@playwright/test": "^1.58.2",
    "@types/express": "^5.0.3",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "pnpm": "10.32.1",
    "prisma": "^7.5.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "turbo": "^2.8.17",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}

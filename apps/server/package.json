{
  "name": "@blackout-manor/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean --out-dir dist",
    "bot:match": "tsx src/cli/botMatch.ts",
    "dev": "tsx watch src/index.ts",
    "lint": "biome check .",
    "local": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --project tsconfig.json --noEmit"
  },
  "dependencies": {
    "@blackout-manor/agents": "workspace:*",
    "@blackout-manor/content": "workspace:*",
    "@blackout-manor/db": "workspace:*",
    "@blackout-manor/engine": "workspace:*",
    "@blackout-manor/replay-viewer": "workspace:*",
    "@blackout-manor/shared": "workspace:*",
    "@colyseus/core": "^0.17.39",
    "@colyseus/ws-transport": "^0.17.9",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "zod": "^4.3.6"
  }
}
